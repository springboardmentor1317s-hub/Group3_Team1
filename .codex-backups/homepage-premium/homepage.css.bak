.home {
  font-family: Arial, sans-serif;
  background: linear-gradient(180deg, #ffffff 0%, #f7f8ff 100%);
  color: #10203c;
}

.landing-header {
  position: sticky;
  top: 0;
  z-index: 20;
  backdrop-filter: blur(22px);
  background:
    linear-gradient(180deg, rgba(252, 252, 255, 0.92), rgba(241, 245, 255, 0.76));
  border-bottom: 1px solid rgba(93, 112, 173, 0.08);
  box-shadow: 0 18px 40px rgba(24, 39, 75, 0.1);
}

.landing-header::before {
  content: "";
  position: absolute;
  left: 50%;
  top: 10px;
  width: min(1200px, calc(100% - 24px));
  height: calc(100% - 20px);
  transform: translateX(-50%);
  border-radius: 24px;
  background:
    radial-gradient(circle at 24% 20%, rgba(255, 255, 255, 0.96), rgba(255, 255, 255, 0.28) 30%, transparent 46%),
    radial-gradient(circle at 78% 26%, rgba(255, 255, 255, 0.42), transparent 30%),
    linear-gradient(135deg, rgba(240, 238, 255, 0.92), rgba(222, 227, 255, 0.82) 48%, rgba(213, 220, 255, 0.72) 100%);
  border: 1px solid rgba(255, 255, 255, 0.76);
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.96),
    inset 0 -1px 0 rgba(177, 190, 244, 0.3),
    0 18px 34px rgba(101, 113, 196, 0.12);
  pointer-events: none;
}

.landing-header::after {
  content: "";
  display: block;
  height: 2px;
  background: linear-gradient(90deg, rgba(85, 105, 246, 0), rgba(91, 108, 242, 0.72), rgba(220, 138, 191, 0.62), rgba(240, 183, 98, 0.58), rgba(85, 105, 246, 0));
}

.header-row {
  position: relative;
  max-width: 1240px;
  min-height: 86px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18px;
  padding: 16px 28px 14px;
}

.brand-block {
  display: flex;
  align-items: center;
  gap: 14px;
  text-decoration: none;
  flex: 0 0 auto;
  padding-right: 14px;
}

.brand-block::after {
  content: "";
  width: 1px;
  height: 42px;
  background: linear-gradient(180deg, rgba(141, 156, 214, 0), rgba(141, 156, 214, 0.6), rgba(141, 156, 214, 0));
}

.brand-logo {
  width: 56px;
  height: 56px;
  object-fit: contain;
  padding: 7px;
  border-radius: 18px;
  background:
    radial-gradient(circle at 30% 25%, rgba(255, 255, 255, 0.98), rgba(255, 255, 255, 0.78) 35%, rgba(230, 237, 255, 0.96) 100%);
  box-shadow:
    0 14px 28px rgba(16, 32, 60, 0.14),
    inset 0 1px 0 rgba(255, 255, 255, 0.9);
}

.brand-copy {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.brand-name {
  display: flex;
  align-items: baseline;
  gap: 0.32rem;
  font-family: "Georgia", "Times New Roman", serif;
  font-size: 1.9rem;
  font-weight: 700;
  letter-spacing: -0.04em;
  line-height: 1;
}

.brand-campus,
.brand-eventhub {
  color: #10203c;
  background: none;
  -webkit-background-clip: text;
  -webkit-text-fill-color: initial;
}

.nav-links {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 6px;
  margin-left: auto;
  padding: 6px;
  border-radius: 999px;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.88), rgba(239, 244, 255, 0.72));
  border: 1px solid rgba(143, 159, 221, 0.18);
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.9),
    0 12px 24px rgba(55, 73, 135, 0.06);
}

.nav-link {
  position: relative;
  padding: 10px 14px;
  border-radius: 999px;
  text-decoration: none;
  font-size: 0.96rem;
  font-weight: 600;
  color: #334362;
  transition: all 0.22s ease;
}

.nav-link::after {
  content: "";
  position: absolute;
  left: 16px;
  right: 16px;
  bottom: 8px;
  height: 2px;
  border-radius: 999px;
  background: linear-gradient(90deg, #5c68f3, #d579c7, #efb168);
  transform: scaleX(0);
  transform-origin: center;
  transition: transform 0.22s ease;
}

.nav-link:hover,
.nav-link.active {
  color: #172746;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(247, 248, 255, 0.95));
  box-shadow: 0 12px 22px rgba(16, 32, 60, 0.09);
}

.nav-link:hover::after,
.nav-link.active::after {
  transform: scaleX(1);
}

.nav-actions {
  display: flex;
  align-items: center;
  gap: 8px;
  flex: 0 0 auto;
  padding: 4px;
  border-radius: 999px;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.52), rgba(246, 248, 255, 0.34));
}

.header-btn {
  padding: 10px 16px;
  border-radius: 999px;
  text-decoration: none;
  font-weight: 700;
  font-size: 0.95rem;
  white-space: nowrap;
  transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease;
}

.header-btn:hover {
  transform: translateY(-2px);
}

.header-btn-secondary {
  color: #3450be;
  background: linear-gradient(180deg, rgba(255, 255, 255, 1), rgba(242, 246, 255, 0.96));
  border: 1px solid rgba(92, 110, 215, 0.14);
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.9),
    0 10px 18px rgba(16, 32, 60, 0.08);
}

.header-btn-primary {
  color: #ffffff;
  background: linear-gradient(135deg, #4f63ff 0%, #7259ff 54%, #d67ac3 100%);
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.2),
    0 14px 28px rgba(109, 89, 255, 0.28);
}

.hero {
  position: relative;
  overflow: hidden;
  min-height: 560px;
  background:
    linear-gradient(90deg, rgba(70, 93, 227, 0.46), rgba(188, 98, 241, 0.22)),
    url('../../assets/homepage-reference-bg.jpeg');
  background-size: cover;
  background-position: center;
}

.hero::after {
  content: "";
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at left center, rgba(255, 255, 255, 0.18), transparent 34%);
  pointer-events: none;
}

.hero-shell {
  position: relative;
  z-index: 1;
  max-width: 1240px;
  margin: 0 auto;
  min-height: 560px;
  display: grid;
  grid-template-columns: minmax(0, 520px) 1fr;
  align-items: center;
  gap: 32px;
  padding: 36px 32px 88px;
}

.hero-copy {
  color: #ffffff;
}

.hero-kicker {
  margin: 0 0 12px;
  font-size: 0.88rem;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.88);
}

.hero-title {
  margin: 0;
  font-size: clamp(3rem, 5.8vw, 4.8rem);
  font-weight: 800;
  line-height: 1.08;
  letter-spacing: -0.06em;
  color: #ffffff;
}

.hero-text {
  max-width: 640px;
  margin: 22px 0 0;
  font-size: 1.22rem;
  line-height: 1.75;
  color: rgba(255, 255, 255, 0.92);
}

.hero-actions {
  display: flex;
  gap: 14px;
  margin-top: 28px;
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 172px;
  padding: 14px 24px;
  border-radius: 14px;
  text-decoration: none;
  font-weight: 700;
  font-size: 1rem;
  transition: transform 0.25s ease, box-shadow 0.25s ease;
}

.btn:hover {
  transform: translateY(-2px);
}

.btn.primary {
  color: #ffffff;
  border: 1px solid rgba(255, 255, 255, 0.55);
  background: linear-gradient(135deg, rgba(87, 101, 247, 0.92), rgba(116, 83, 255, 0.92));
  box-shadow: 0 18px 34px rgba(63, 79, 204, 0.3);
}

.btn.secondary {
  color: #4e56d0;
  border: 1px solid rgba(255, 255, 255, 0.5);
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 18px 30px rgba(255, 255, 255, 0.18);
}

.hero-visual {
  min-height: 360px;
}

.stats-panel {
  max-width: 1080px;
  margin: -52px auto 0;
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  background:
    radial-gradient(circle at 12% 18%, rgba(255, 255, 255, 0.96), rgba(255, 255, 255, 0.2) 24%, transparent 38%),
    radial-gradient(circle at top right, rgba(255, 244, 214, 0.52), transparent 24%),
    linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(244, 247, 255, 0.95) 34%, rgba(231, 238, 255, 0.94) 68%, rgba(247, 241, 255, 0.95) 100%);
  backdrop-filter: blur(14px);
  border-radius: 28px;
  border: 1px solid rgba(255, 255, 255, 0.96);
  box-shadow:
    0 32px 68px rgba(70, 93, 227, 0.18),
    inset 0 1px 0 rgba(255, 255, 255, 0.92),
    inset 0 -1px 0 rgba(191, 203, 240, 0.34);
  overflow: hidden;
}

.stats-panel::before {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(115deg, rgba(255, 255, 255, 0.24), transparent 28%, transparent 72%, rgba(255, 255, 255, 0.14));
  pointer-events: none;
}

.stats-panel::after {
  content: "";
  position: absolute;
  inset: 10px;
  border-radius: 22px;
  border: 1px solid rgba(255, 255, 255, 0.52);
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.58),
    inset 0 -1px 0 rgba(176, 191, 235, 0.18);
  pointer-events: none;
}

.stat-item {
  position: relative;
  padding: 34px 20px;
  text-align: center;
  border-right: 1px solid rgba(80, 95, 140, 0.08);
}

.stat-item:last-child {
  border-right: 0;
}

.stat-item::after {
  content: "";
  position: absolute;
  inset: 12px;
  border-radius: 20px;
  border: 1px solid rgba(220, 227, 246, 0.92);
  background:
    radial-gradient(circle at top left, rgba(255, 255, 255, 0.38), transparent 34%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.3), rgba(255, 255, 255, 0.08));
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.8),
    0 10px 18px rgba(120, 135, 214, 0.08);
  pointer-events: none;
}

.stat-item::before {
  content: "";
  position: absolute;
  top: 18px;
  left: 50%;
  width: 62%;
  height: 1px;
  transform: translateX(-50%);
  background: linear-gradient(90deg, rgba(117, 131, 214, 0), rgba(117, 131, 214, 0.36), rgba(232, 179, 110, 0.28), rgba(117, 131, 214, 0));
  pointer-events: none;
}

.stat-item h2 {
  margin: 0 0 10px;
  font-size: clamp(2.4rem, 4vw, 3.4rem);
  font-weight: 800;
  color: #1a2f5c;
  position: relative;
  z-index: 1;
  text-shadow:
    0 1px 0 rgba(255, 255, 255, 0.62),
    0 10px 24px rgba(135, 151, 223, 0.18);
}

.stat-item p {
  margin: 0;
  font-size: 1.04rem;
  color: #495a7f;
  position: relative;
  z-index: 1;
  font-weight: 600;
}

.featured-events {
  max-width: 1240px;
  margin: 0 auto;
  padding: 78px 32px 48px;
}

.section-heading {
  text-align: center;
  margin-bottom: 30px;
}

.section-kicker {
  margin: 0 0 8px;
  font-size: 0.86rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #6d78cb;
}

.section-heading h2,
.about-card h2 {
  margin: 0;
  font-size: clamp(2rem, 3vw, 2.6rem);
  color: #1d2b4a;
}

.event-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 26px;
}

.event-card {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 18px;
  padding: 24px;
  border-radius: 26px;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.97), rgba(248, 250, 255, 0.96));
  border: 1px solid rgba(255, 255, 255, 0.72);
  box-shadow:
    0 20px 44px rgba(68, 81, 155, 0.12),
    inset 0 1px 0 rgba(255, 255, 255, 0.85);
  overflow: hidden;
  min-height: 100%;
  transition: transform 0.28s ease, box-shadow 0.28s ease, border-color 0.28s ease;
}

.event-card > * {
  position: relative;
  z-index: 1;
}

.event-card-top {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 76px 1fr;
  align-items: start;
  gap: 18px;
}

.event-poster {
  position: relative;
  z-index: 1;
  width: 76px;
  height: 76px;
  border-radius: 22px;
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.82);
  box-shadow:
    0 16px 30px rgba(108, 116, 216, 0.18),
    inset 0 1px 0 rgba(255, 255, 255, 0.88);
}

.event-poster img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.35s ease;
}

.event-poster-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.9);
}

.event-headline {
  min-width: 0;
}

.event-card::before {
  content: "";
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at top right, rgba(255, 255, 255, 0.86), transparent 34%),
    radial-gradient(circle at bottom left, rgba(125, 146, 255, 0.1), transparent 34%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.12), transparent 55%);
  pointer-events: none;
}

.event-card::after {
  content: "";
  position: absolute;
  inset: auto 18px 0;
  height: 1px;
  background: linear-gradient(90deg, rgba(102, 116, 214, 0), rgba(102, 116, 214, 0.24), rgba(225, 137, 190, 0.22), rgba(102, 116, 214, 0));
}

.event-card-pink {
  background:
    radial-gradient(circle at top right, rgba(255, 255, 255, 0.74), transparent 32%),
    radial-gradient(circle at left bottom, rgba(255, 203, 233, 0.34), transparent 34%),
    linear-gradient(135deg, rgba(255, 245, 252, 0.98), rgba(250, 239, 255, 0.98));
}

.event-card-peach {
  background:
    radial-gradient(circle at top right, rgba(255, 255, 255, 0.74), transparent 32%),
    radial-gradient(circle at left bottom, rgba(255, 222, 188, 0.32), transparent 34%),
    linear-gradient(135deg, rgba(255, 247, 236, 0.98), rgba(255, 240, 247, 0.98));
}

.event-card-blue {
  background:
    radial-gradient(circle at top right, rgba(255, 255, 255, 0.74), transparent 32%),
    radial-gradient(circle at left bottom, rgba(200, 230, 255, 0.32), transparent 34%),
    linear-gradient(135deg, rgba(241, 249, 255, 0.98), rgba(246, 242, 255, 0.98));
}

.event-badge {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.7rem;
  font-weight: 800;
  color: #5a58d8;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 12px 24px rgba(108, 116, 216, 0.16);
}

.event-headline h3 {
  margin: 2px 0 8px;
  font-size: 1.5rem;
  line-height: 1.2;
  color: #1f2c4e;
  letter-spacing: -0.03em;
}

.event-location,
.event-date {
  margin: 0;
  color: #5f6c89;
}

.event-location {
  font-size: 1rem;
  font-weight: 600;
  color: #677594;
}

.event-content {
  position: relative;
  z-index: 1;
  display: grid;
  gap: 10px;
  flex: 1 1 auto;
  padding-top: 6px;
}

.event-date {
  font-size: 0.98rem;
  font-weight: 700;
  color: #314665;
}

.event-meta {
  margin: 0;
  font-size: 0.95rem;
  line-height: 1.65;
  color: #6a7590;
}

.event-card-bottom {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  margin-top: auto;
  padding-top: 8px;
  border-top: 1px solid rgba(111, 126, 207, 0.14);
}

.event-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 9px 14px;
  border-radius: 999px;
  font-size: 0.84rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: #5b65d9;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(245, 247, 255, 0.86));
  border: 1px solid rgba(115, 126, 222, 0.1);
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.88),
    0 10px 16px rgba(90, 101, 189, 0.08);
}

.event-link {
  position: relative;
  z-index: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12px 18px;
  border-radius: 14px;
  text-decoration: none;
  white-space: nowrap;
  font-weight: 700;
  color: #ffffff;
  background: linear-gradient(135deg, #5565f3 0%, #7a5ef5 58%, #d87bbf 100%);
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.22),
    0 14px 24px rgba(89, 99, 245, 0.22);
  transition: transform 0.24s ease, box-shadow 0.24s ease;
}

.event-card:hover {
  transform: translateY(-8px);
  border-color: rgba(184, 191, 249, 0.68);
  box-shadow:
    0 28px 54px rgba(68, 81, 155, 0.16),
    inset 0 1px 0 rgba(255, 255, 255, 0.9);
}

.event-card:hover .event-poster img {
  transform: scale(1.06);
}

.event-card:hover .event-link {
  transform: translateY(-1px);
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.22),
    0 18px 28px rgba(110, 93, 243, 0.26);
}

.event-state-card {
  padding: 28px 24px;
  border-radius: 24px;
  text-align: center;
  font-size: 1rem;
  color: #53617d;
  background: rgba(255, 255, 255, 0.82);
  box-shadow: 0 18px 40px rgba(68, 81, 155, 0.08);
}

.registered-colleges-section {
  max-width: 1240px;
  margin: 0 auto;
  padding: 10px 32px 32px;
}

.college-showcase {
  position: relative;
  overflow: hidden;
  padding: 18px 0 26px;
  cursor: grab;
  user-select: none;
  touch-action: pan-y;
}

.college-showcase.is-dragging {
  cursor: grabbing;
}

.college-showcase::before,
.college-showcase::after {
  content: "";
  position: absolute;
  top: 0;
  bottom: 0;
  width: 120px;
  z-index: 2;
  pointer-events: none;
}

.college-showcase::before {
  left: 0;
  background: linear-gradient(90deg, #f8f9ff 18%, rgba(248, 249, 255, 0));
}

.college-showcase::after {
  right: 0;
  background: linear-gradient(270deg, #f8f9ff 18%, rgba(248, 249, 255, 0));
}

.college-stage {
  position: relative;
  min-height: 228px;
  display: flex;
  align-items: center;
  justify-content: center;
  perspective: 1400px;
}

.college-card {
  position: absolute;
  left: 50%;
  top: 50%;
  display: flex;
  align-items: center;
  gap: 16px;
  width: min(100%, 340px);
  padding: 20px 22px;
  border-radius: 24px;
  background:
    radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.98), rgba(255, 255, 255, 0.18) 28%, transparent 42%),
    radial-gradient(circle at 82% 24%, rgba(255, 222, 168, 0.68), transparent 28%),
    linear-gradient(135deg, rgba(255, 255, 255, 1) 0%, rgba(244, 248, 255, 0.99) 24%, rgba(220, 230, 252, 0.98) 52%, rgba(243, 233, 255, 0.99) 78%, rgba(223, 232, 252, 1) 100%);
  border: 1px solid rgba(255, 255, 255, 0.96);
  box-shadow:
    0 24px 54px rgba(66, 84, 162, 0.22),
    inset 0 1px 0 rgba(255, 255, 255, 0.96),
    inset 0 -1px 0 rgba(182, 194, 231, 0.5);
  transition:
    transform 1.15s cubic-bezier(0.23, 1, 0.32, 1),
    opacity 0.7s ease,
    box-shadow 0.7s ease,
    border-color 0.7s ease,
    filter 0.7s ease;
  transform: translate(-50%, -50%) scale(0.78) rotateY(10deg);
  opacity: 0;
  filter: blur(2px);
  pointer-events: none;
}

.college-card::before {
  content: "";
  position: absolute;
  inset: 1px;
  border-radius: 23px;
  background:
    linear-gradient(120deg, rgba(255, 255, 255, 0.72), transparent 28%, transparent 68%, rgba(255, 255, 255, 0.48)),
    linear-gradient(180deg, rgba(255, 255, 255, 0.22), transparent 55%);
  pointer-events: none;
}

.college-card::after {
  content: "";
  position: absolute;
  left: 20px;
  right: 20px;
  bottom: 0;
  height: 1px;
  background: linear-gradient(90deg, rgba(122, 137, 210, 0), rgba(122, 137, 210, 0.38), rgba(230, 174, 114, 0.3), rgba(122, 137, 210, 0));
  pointer-events: none;
}

.college-badge {
  flex: 0 0 58px;
  width: 58px;
  height: 58px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18px;
  font-size: 1.1rem;
  font-weight: 800;
  letter-spacing: 0.06em;
  color: #3147d1;
  background:
    radial-gradient(circle at 30% 28%, rgba(255, 255, 255, 0.98), rgba(255, 255, 255, 0.74) 34%, rgba(226, 234, 252, 0.94) 100%);
  border: 1px solid rgba(255, 255, 255, 0.96);
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.92),
    0 16px 28px rgba(89, 99, 245, 0.18);
}

.college-copy {
  min-width: 0;
}

.college-copy h3 {
  margin: 0 0 6px;
  font-size: 1.12rem;
  line-height: 1.35;
  color: #10203d;
  letter-spacing: -0.02em;
  text-shadow: 0 1px 0 rgba(255, 255, 255, 0.6);
}

.college-copy p {
  margin: 0;
  font-size: 0.92rem;
  line-height: 1.55;
  color: #4f5f7d;
}

.about-strip {
  max-width: 1240px;
  margin: 0 auto;
  padding: 12px 32px 72px;
}

.about-shell {
  display: grid;
  grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
  gap: 28px;
  align-items: center;
  padding: 34px 36px;
  border-radius: 30px;
  background:
    radial-gradient(circle at top right, rgba(255, 255, 255, 0.78), transparent 32%),
    linear-gradient(135deg, rgba(246, 248, 255, 0.98), rgba(255, 255, 255, 0.98));
  box-shadow: 0 18px 42px rgba(57, 74, 145, 0.08);
}

.about-copy h2 {
  margin: 0;
  font-size: clamp(2rem, 3.2vw, 2.9rem);
  line-height: 1.16;
  color: #172746;
}

.about-lead,
.about-body,
.about-vision-card p {
  margin: 18px 0 0;
  font-size: 1.04rem;
  line-height: 1.8;
  color: #53617d;
}

.about-visuals {
  position: relative;
  min-height: auto;
  display: grid;
  gap: 18px;
  align-items: start;
}

.about-image-card {
  margin: 0;
  overflow: hidden;
  border-radius: 26px;
  border: 1px solid rgba(255, 255, 255, 0.86);
  box-shadow:
    0 22px 44px rgba(80, 97, 171, 0.14),
    inset 0 1px 0 rgba(255, 255, 255, 0.84);
}

.about-image-card img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
  background: linear-gradient(135deg, rgba(247, 249, 255, 0.98), rgba(238, 243, 255, 0.92));
}

.about-image-card-primary {
  width: 100%;
  aspect-ratio: 1536 / 604;
}

.about-image-card-secondary {
  position: relative;
  right: auto;
  bottom: auto;
  width: 100%;
  aspect-ratio: 1536 / 604;
}

.about-highlights {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20px;
  margin-top: 26px;
}

.about-feature {
  padding: 24px;
  border-radius: 24px;
  background:
    radial-gradient(circle at top right, rgba(255, 255, 255, 0.72), transparent 30%),
    linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(242, 246, 255, 0.96));
  border: 1px solid rgba(255, 255, 255, 0.86);
  box-shadow: 0 16px 34px rgba(57, 74, 145, 0.08);
}

.about-feature-number {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 48px;
  height: 32px;
  padding: 0 12px;
  border-radius: 999px;
  margin-bottom: 14px;
  font-size: 0.82rem;
  font-weight: 800;
  letter-spacing: 0.08em;
  color: #4b5ed9;
  background: rgba(235, 240, 255, 0.94);
}

.about-feature h3,
.about-vision-card h3 {
  margin: 0;
  font-size: 1.18rem;
  line-height: 1.4;
  color: #1c2d4d;
}

.about-feature p {
  margin: 12px 0 0;
  font-size: 0.98rem;
  line-height: 1.72;
  color: #5c6a86;
}

.about-vision-card {
  margin-top: 24px;
  padding: 28px 30px;
  border-radius: 26px;
  background: linear-gradient(135deg, rgba(243, 246, 255, 0.98), rgba(255, 255, 255, 0.98));
  border: 1px solid rgba(255, 255, 255, 0.88);
  box-shadow: 0 18px 40px rgba(57, 74, 145, 0.08);
}

.footer-section {
  padding: 0 0 18px;
  background: #1e293b;
  color: #cbd5f5;
}

.footer-shell {
  max-width: 1240px;
  margin: 0 auto;
  padding: 36px 32px 24px;
  display: grid;
  grid-template-columns: minmax(260px, 0.9fr) minmax(0, 1.1fr);
  gap: 26px;
}

.footer-brand h3 {
  margin: 0;
  font-size: 1.7rem;
  color: #ffffff;
}

.footer-brand p:last-child {
  margin: 14px 0 0;
  max-width: 480px;
  line-height: 1.8;
  color: #c7d3ea;
}

.footer-contact-grid {
  display: grid;
  grid-template-columns: 1.35fr 1fr 1.15fr;
  gap: 18px;
}

.footer-contact-card {
  position: relative;
  padding: 20px 20px;
  border-radius: 22px;
  background:
    radial-gradient(circle at top right, rgba(140, 163, 255, 0.18), transparent 32%),
    linear-gradient(135deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.04));
  border: 1px solid rgba(255, 255, 255, 0.1);
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.08),
    0 16px 32px rgba(0, 0, 0, 0.14);
  overflow: hidden;
}

.footer-contact-card::before {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(120deg, rgba(255, 255, 255, 0.1), transparent 38%, transparent 62%, rgba(255, 255, 255, 0.06));
  pointer-events: none;
}

.footer-contact-label {
  display: inline-block;
  margin-bottom: 10px;
  font-size: 0.82rem;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #91a7ff;
}

.footer-contact-card p {
  margin: 0;
  line-height: 1.7;
  color: #f3f7ff;
  overflow-wrap: anywhere;
  word-break: break-word;
}

.footer-email-line {
  white-space: nowrap;
}

.footer-copy {
  margin: 0;
  text-align: center;
  padding: 0 18px;
  color: #cbd5f5;
}

@media (max-width: 1280px) {
  .header-row,
  .hero-shell,
  .featured-events,
  .about-strip,
  .registered-colleges-section,
  .footer-shell {
    padding-left: 24px;
    padding-right: 24px;
  }

  .landing-header::before {
    width: min(1160px, calc(100% - 20px));
  }

  .hero-title {
    font-size: clamp(2.8rem, 5vw, 4.2rem);
  }
}

@media (max-width: 1100px) {
  .header-row {
    flex-wrap: wrap;
    justify-content: center;
    min-height: auto;
  }

  .brand-block::after {
    display: none;
  }

  .nav-links {
    margin-left: 0;
    order: 3;
    width: 100%;
  }

  .hero-shell {
    grid-template-columns: 1fr;
    min-height: 520px;
    padding-bottom: 80px;
  }

  .hero-visual {
    display: none;
  }

  .stats-panel {
    margin-left: 24px;
    margin-right: 24px;
    grid-template-columns: repeat(2, 1fr);
  }

  .event-grid {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 900px) {
  .brand-name {
    font-size: 1.75rem;
  }

  .nav-link {
    padding: 10px 12px;
    font-size: 0.95rem;
  }

  .hero {
    min-height: 520px;
    background-position: 60% center;
  }

  .hero-text {
    font-size: 1.08rem;
    line-height: 1.68;
  }

  .stats-panel {
    border-radius: 24px;
  }

  .event-card {
    padding: 22px;
  }

  .event-card-top {
    grid-template-columns: 64px 1fr;
    gap: 16px;
  }

  .event-poster {
    width: 64px;
    height: 64px;
    border-radius: 18px;
  }
}

@media (max-width: 768px) {
  .header-row,
  .featured-events,
  .about-strip,
  .hero-shell,
  .registered-colleges-section,
  .footer-shell {
    padding-left: 18px;
    padding-right: 18px;
  }

  .header-row {
    min-height: auto;
    flex-direction: column;
    align-items: stretch;
    gap: 14px;
    padding-top: 16px;
    padding-bottom: 12px;
  }

  .brand-block,
  .nav-links,
  .nav-actions {
    justify-content: center;
  }

  .brand-block {
    width: 100%;
  }

  .brand-name {
    font-size: 1.65rem;
  }

  .nav-links {
    width: 100%;
    gap: 6px;
    padding: 8px;
    border-radius: 24px;
  }

  .nav-link {
    flex: 1 1 calc(33.333% - 6px);
    min-width: 92px;
    text-align: center;
  }

  .nav-actions {
    width: 100%;
  }

  .header-btn {
    flex: 1 1 0;
    text-align: center;
  }

  .hero {
    min-height: 500px;
    background-position: 62% center;
  }

  .hero-shell {
    min-height: 500px;
    padding-top: 28px;
    padding-bottom: 72px;
  }

  .hero-text {
    font-size: 1rem;
  }

  .hero-actions {
    flex-direction: column;
    align-items: stretch;
  }

  .stats-panel {
    grid-template-columns: 1fr;
    margin-left: 18px;
    margin-right: 18px;
  }

  .stat-item {
    border-right: 0;
    border-bottom: 1px solid rgba(80, 95, 140, 0.08);
  }

  .stat-item:last-child {
    border-bottom: 0;
  }

  .event-card {
    gap: 16px;
  }

  .event-link {
    width: 100%;
  }

  .event-card-bottom {
    flex-direction: column;
    align-items: stretch;
  }

  .about-shell {
    grid-template-columns: 1fr;
    padding: 28px 22px;
  }

  .footer-shell {
    grid-template-columns: 1fr;
  }

  .footer-contact-grid {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 560px) {
  .landing-header {
    backdrop-filter: blur(14px);
  }

  .header-row,
  .featured-events,
  .about-strip,
  .hero-shell,
  .registered-colleges-section,
  .footer-shell {
    padding-left: 14px;
    padding-right: 14px;
  }

  .brand-logo {
    width: 48px;
    height: 48px;
    border-radius: 14px;
  }

  .brand-name {
    font-size: 1.42rem;
  }

  .nav-links {
    border-radius: 18px;
  }

  .nav-link {
    flex: 1 1 calc(50% - 6px);
    padding: 10px 12px;
    font-size: 0.92rem;
  }

  .hero {
    min-height: 470px;
    background-position: 64% center;
  }

  .hero-shell {
    min-height: 470px;
    padding-top: 22px;
    padding-bottom: 64px;
  }

  .hero-title {
    font-size: clamp(2.2rem, 9.5vw, 3.1rem);
    line-height: 1.12;
  }

  .hero-text {
    margin-top: 16px;
    font-size: 0.98rem;
    line-height: 1.62;
  }

  .btn {
    width: 100%;
    min-width: 0;
    padding: 13px 18px;
  }

  .stats-panel {
    margin-top: -40px;
    margin-left: 14px;
    margin-right: 14px;
    border-radius: 20px;
  }

  .stat-item {
    padding: 26px 16px;
  }

  .stat-item h2 {
    font-size: 2.2rem;
  }

  .featured-events {
    padding-top: 56px;
    padding-bottom: 36px;
  }

  .section-heading {
    margin-bottom: 22px;
  }

  .event-card {
    gap: 14px;
    padding: 18px;
    border-radius: 20px;
  }

  .event-card-top {
    grid-template-columns: 54px 1fr;
    gap: 14px;
  }

  .event-poster {
    width: 54px;
    height: 54px;
    border-radius: 15px;
  }

  .event-badge {
    font-size: 1.3rem;
  }

  .event-headline h3 {
    font-size: 1.18rem;
  }

  .event-meta {
    font-size: 0.9rem;
  }

  .about-shell {
    border-radius: 22px;
    padding: 24px 18px;
  }

  .about-highlights {
    grid-template-columns: 1fr;
  }

  .about-visuals {
    min-height: auto;
  }

  .about-image-card-primary {
    aspect-ratio: 1536 / 604;
  }

  .about-image-card-secondary {
    width: 100%;
    aspect-ratio: 1536 / 604;
  }

  .college-stage {
    min-height: 190px;
  }

  .college-card {
    width: min(100%, 270px);
    padding: 16px 16px;
    border-radius: 18px;
  }

  .college-badge {
    width: 50px;
    height: 50px;
    flex-basis: 50px;
    border-radius: 15px;
    font-size: 1rem;
  }

  footer {
    font-size: 0.92rem;
    line-height: 1.5;
  }
}

@media (max-width: 860px) {
  .college-showcase::before,
  .college-showcase::after {
    width: 56px;
  }

  .college-stage {
    min-height: 196px;
  }

  .college-card {
    width: min(100%, 300px);
  }

}

@media (min-width: 861px) and (max-width: 1180px) {
  .college-stage {
    min-height: 212px;
  }

  .college-card {
    width: min(100%, 312px);
  }

}

@media (max-width: 390px) {
  .brand-name {
    font-size: 1.26rem;
  }

  .header-row {
    gap: 10px;
    padding-top: 14px;
  }

  .nav-link {
    flex-basis: 100%;
  }

  .header-btn {
    padding: 10px 14px;
    font-size: 0.94rem;
  }

  .hero-title {
    font-size: 2rem;
  }

  .hero-kicker,
  .section-kicker {
    letter-spacing: 0.1em;
  }

  .stat-item p,
  .event-location,
  .event-date,
  .about-card p:last-child {
    font-size: 0.94rem;
  }
}
